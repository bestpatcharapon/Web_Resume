<section class="projects-section" id="projects">
  <div class="section-header">
    <%= icon("folder", size: 24, color: "#728559") %>
    <h2>Projects <span class="header-count-badge"><%= projects.size %></span></h2>
  </div>
  <p class="section-subtitle">Featured projects and contributions</p>

  <div class="projects-carousel-container" id="projects-carousel-container">
    <div class="projects-track" id="projects-track">
      <% projects.each do |project| %>
        <div class="project-card card">
          <div class="project-card-body">
            <div class="project-card-top">
              <div class="project-title-wrapper">
                <h3 class="project-title"><%= project[:title] %></h3>
                <span class="project-status status-<%= project[:status] ? project[:status].downcase : 'finished' %>">
                  <span class="status-dot"></span>
                  <%= project[:status] || "Finished" %>
                </span>
              </div>
              <p class="project-description"><%= project[:description] %></p>
            </div>

            <div class="project-tags">
              <% project[:tags].each do |tag_name| %>
                <span class="tag"><%= tag_name %></span>
              <% end %>
            </div>
            
            <% if project[:link] %>
            <% end %>
          </div>

          <% if project[:images] && project[:images].is_a?(Array) %>
            <div class="project-preview project-preview-double">
              <% project[:images].each do |img| %>
                <img src="<%= img %>" alt="<%= project[:title] %>" class="project-image-half clickable-image" loading="lazy" data-title="<%= project[:title] %>" />
              <% end %>
            </div>
          <% elsif project[:image] %>
            <div class="project-preview">
              <img src="<%= project[:image] %>" alt="<%= project[:title] %>" class="project-image clickable-image" loading="lazy" data-title="<%= project[:title] %>" />
            </div>
          <% else %>
            <div class="project-preview project-preview-icon">
              <div class="project-icon-large" style="color: <%= project[:color] %>;">
                <i class="<%= project[:icon] %>"></i>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    
    <div class="projects-nav-dots" id="projects-nav-dots">
      <!-- Dots will be generated via JavaScript -->
    </div>
  </div>
</section>
