<!-- Chatbot Widget -->
<div class="chatbot-widget" id="chatbotWidget">
  <!-- Chat Toggle Button -->
  <button class="chatbot-toggle" id="chatbotToggle" title="Chat with AI Assistant">
    <svg class="chat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg class="close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
    <span class="chatbot-badge" id="chatbotBadge">AI</span>
  </button>

  <!-- Chat Window -->
  <div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
      <div class="chatbot-header-info">
        <div class="chatbot-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L9 7H4l3.5 5L6 17l6-3 6 3-1.5-5L20 7h-5L12 2z"/>
          </svg>
        </div>
        <div>
          <h3>Best AI</h3>
          <span class="chatbot-status">
            <span class="status-dot"></span>
            Online
          </span>
        </div>
      </div>
      <button class="chatbot-close" id="chatbotClose">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="chatbot-messages" id="chatbotMessages">
      <div class="chat-message bot-message">
        <div class="message-avatar bot-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L9 7H4l3.5 5L6 17l6-3 6 3-1.5-5L20 7h-5L12 2z"/>
          </svg>
        </div>
        <div class="message-bubble">
          สวัสดีครับ! ผม Best Bot AI ผู้ช่วยประจำ Portfolio ของ Best นะครับ ถามอะไรได้เลย!
        </div>
      </div>
    </div>

    <div class="chatbot-input-area">
      <div class="chatbot-suggestions" id="chatbotSuggestions">
        <button class="suggestion-chip" data-prompt="Best ทำอะไรบ้าง?">Best ทำอะไรบ้าง?</button>
        <button class="suggestion-chip" data-prompt="ทักษะของ Best มีอะไรบ้าง?">ทักษะ</button>
        <button class="suggestion-chip" data-prompt="ประสบการณ์ทำงานของ Best?">ประสบการณ์</button>
      </div>
      <form class="chatbot-form" id="chatbotForm">
        <input
          type="text"
          class="chatbot-input"
          id="chatbotInput"
          placeholder="ถาม AI เกี่ยวกับ Best..."
          autocomplete="off"
        />
        <button type="submit" class="chatbot-send" id="chatbotSend">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>
