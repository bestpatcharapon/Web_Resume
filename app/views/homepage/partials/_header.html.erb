<header class="header">
  <% [
    { id: "about", icon: "user", label: "About", active: true },
    { id: "skills", icon: "code", label: "Skills", active: false },
    { id: "projects", icon: "folder", label: "Projects", active: false },
    { id: "experience", icon: "briefcase", label: "Experience", active: false }
  ].each do |link| %>
    <%= link_to "##{link[:id]}", class: "nav-link #{'active' if link[:active]}" do %>
      <%= icon(link[:icon]) %>
      <%= link[:label] %>
    <% end %>
  <% end %>
</header>
