<section class="skills-section" id="skills">
  <div class="skills-grid">
    <!-- Soft Skills -->
    <div class="card">
      <div class="card-header">
        <%= icon("heart", size: 20, color: "#e74c3c") %>
        Soft Skills
      </div>
      <div class="skills-grid-two-col">
        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-lightbulb",
            name: "Problem Solving",
            percentage: 85 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-brain",
            name: "Analytical Thinking",
            percentage: 85 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-magnifying-glass",
            name: "Attention to Detail",
            percentage: 90 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-comments",
            name: "Communication",
            percentage: 80 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-bug",
            name: "Critical Thinking",
            percentage: 88 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-users",
            name: "Teamwork",
            percentage: 90 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-clock",
            name: "Time Management",
            percentage: 82 %>

        <%= render "homepage/partials/skill_item",
            icon_class: "fa-solid fa-shield-halved",
            name: "Quality Mindset",
            percentage: 88 %>
      </div>
    </div>

    <!-- Technical Skills - Marquee -->
    <div class="card marquee-card">
      <div class="card-header">
        <%= icon("terminal", size: 20, color: "#3498db") %>
        Technical Skills
      </div>

      <div class="marquee-skills-container">
        <% tech_skills_grouped.each_with_index do |group, idx| %>
          <div class="marquee-row">
            <div class="marquee-category-label"><%= group[:category] %></div>
            <div class="marquee-track-wrapper">
              <% fill_count = group[:skills].size <= 3 ? 3 : 2 %>
              <% items_per_set = group[:skills].size * fill_count %>
              <% duration = (items_per_set * 2.5).round(1) %>
              <div class="marquee-track <%= idx.even? ? 'scroll-left' : 'scroll-right' %>" style="--marquee-duration: <%= duration %>s">
                <% 2.times do %>
                  <div class="marquee-set">
                    <% fill_count.times do %>
                      <% group[:skills].each do |skill| %>
                        <div class="marquee-skill-item">
                          <div class="marquee-skill-icon">
                            <i class="<%= skill[:icon] %>"></i>
                          </div>
                          <div class="marquee-skill-info">
                            <span class="marquee-skill-name"><%= skill[:name] %></span>
                            <span class="marquee-skill-category"><%= group[:category].split('•').first.strip %></span>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <p class="footer-note" style="margin-top: 0.75rem;">
        <%= icon("sparkle", size: 14) %>
        Always learning new technologies
      </p>
    </div>
  </div>
</section>
