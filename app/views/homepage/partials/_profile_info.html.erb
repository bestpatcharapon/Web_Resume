<div class="profile-info">
  <div class="profile-header">
    <h1 class="typing-name" id="typingName">Best Patcharapon</h1>
    <p class="role">
      <%= icon("sparkle", size: 20) %>
      Software Developer | Software Testing
    </p>
    <p class="description">
      Test Engineer with a development background, specializing in software testing and quality assurance. Experienced in manual testing, end-to-end testing, test case design, execution, and defect reporting. Strong understanding of SDLC and Agile practices, with hands-on experience in API validation and dashboard data verification. Technical background in web development using Ruby on Rails and modern web technologies, with strong analytical thinking and problem-solving skills. Passionate about delivering reliable, high-quality software while contributing to development when needed.
    </p>
  </div>

  <!-- Info Cards -->
  <div class="info-grid">
    <%= render "homepage/partials/info_card",
        icon_name: "location",
        title: "Location",
        value: "Chiang Mai, TH" %>

    <%= render "homepage/partials/info_card",
        icon_name: "email",
        title: "Email",
        value: "Patcharaponyo65@gmail.com" %>

    <%= render "homepage/partials/info_card",
        icon_name: "cake",
        title: "Birthday",
        value: "December 4, 2003" %>

    <%= render "homepage/partials/info_card",
        icon_name: "graduation",
        title: "Faculty",
        value: "Computer Engineering" %>

    <%= render "homepage/partials/info_card",
        icon_name: "sparkle",
        title: "Primary Tools",
        value: "Ruby on Rails · Bruno · Manual Testing" %>
  </div>

  <!-- Action Buttons -->
  <div class="action-buttons">
    <%= link_to "https://github.com/bestpatcharapon", class: "btn btn-primary", target: "_blank", rel: "noopener noreferrer" do %>
      <%= icon_filled("github", size: 20) %>
      GitHub Profile
    <% end %>

    <%= link_to "https://www.linkedin.com/in/patcharapon-yoriya-153459357/", class: "btn btn-primary", target: "_blank", rel: "noopener noreferrer" do %>
      <%= icon_filled("linkedin", size: 20) %>
      LinkedIn
    <% end %>

    <%= link_to "/Patcharapon_CV.pdf", class: "btn btn-primary", download: "Patcharapon_CV.pdf" do %>
      <%= icon("download", size: 20) %>
      Download CV
    <% end %>
  </div>
</div>
